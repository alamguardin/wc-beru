---
/** biome-ignore-all lint/correctness/noUnusedImports: false positive */
/** biome-ignore-all assist/source/organizeImports: false positive */
import { Code } from 'astro:components';
import HeroSection from '../components/HeroSection.astro';
import UsageExample from '../components/examples/UsageExample.astro';
import ParamsExample from '../components/examples/ParamsExample.astro';
import PositionsExample from '../components/examples/PositionsExample.astro';
import Layout from '../layouts/Layout.astro';
import ThemeExample from '../components/examples/ThemeExample.astro';
import TypesExample from '../components/examples/TypesExample.astro';
import FullcolorExample from '../components/examples/FullcolorExample .astro';
import * as example from '../const/usageExamples';
---

<Layout>
	<wc-beru></wc-beru>
	<wc-beru id="beru-position"></wc-beru>
	<wc-beru id="beru-theme" theme="light"></wc-beru>
	<wc-beru id="beru-fullcolor" fullcolor></wc-beru>
	<wc-beru id="beru-multiply"></wc-beru>
	<HeroSection></HeroSection>
	<section class="container">
		<h2>Usage</h2>
		<p>Once installed, you need to go to your <span>index.html</span> and use the <span>wc-beru</span> tag.</p>
		<Code code={example.usageExampleOne} theme="catppuccin-latte" lang="html"></Code>
		<p>Assuming that a <span>wc-beru</span> tag already exists in our <span>index.html</span>, we proceed to use the following code block:</p>
		<Code code={example.usageExampleTwo} theme="catppuccin-latte" lang="js"></Code>
		<p>When importing <span>toasts</span>, it automatically detects if there is an instance of our <span>wc-beru</span> element.</p>
		<p>In the example above, we call a <span>display</span> method, which allows us to render our toast; try it yourself:</p>
		<UsageExample></UsageExample>
		<p>It is worth noting that <span>display</span> is not the only available method; <span>toast</span> offers other semantic methods with different styles, which you will discover later on.</p>
	</section>
	<section class="container">
		<h2>Optional parameters</h2>
		<p>The methods offered by <span>toast</span>, such as <span>display</span>, can accept optional parameters apart from the main message. Here is an example:</p>
		<Code code={example.optionalParamsExample} theme="catppuccin-latte" lang="js"></Code>
		<ul>
			<li><span>description</span> (string): Allows us to provide more context to the main message.</li>
			<li><span>closeButton</span> (boolean): Renders a button to dismiss the toast.</li>
			<li><span>beruId</span> (string): Renders the toast in a specific <span>wc-beru</span> instance; we will see an example of this later.</li>
		</ul>
		<ParamsExample></ParamsExample>
	</section>
	<section class="container">
		<h2>Positions</h2>
		<p>Our <span>wc-beru</span> element accepts a <span>position</span> attribute. This attribute allows us to indicate the position where we want our toast to be rendered, and there are only six possible values, which you will see below:</p>
		<PositionsExample></PositionsExample>
	</section>
	<section class="container">
		<h2>Theme</h2>
		<p><span>wc-beru</span> also features a <span>theme</span> attribute that accepts two possible values: <span>light</span> (default value) and <span>dark</span>, allowing you to switch between light and dark modes when rendering the toast.</p>
		<ThemeExample></ThemeExample>
	</section>
	<section class="container">
		<h2>Types</h2>
		<p>As mentioned earlier, <span>toast</span> offers other methods; it provides five in total, including <span>display</span>. Here is a demonstration using the other available methods:</p>
		<TypesExample></TypesExample>
	</section>
	<section class="container">
		<h2>Rich colors</h2>
		<p><span>wc-beru</span> accepts a <span>fullcolor</span> attribute, which forces the toast to use colors based on its type, thereby enhancing its visual purpose.</p>
		<Code code={example.fullcolorExample} theme="catppuccin-latte" lang="html"></Code>
		<FullcolorExample></FullcolorExample>
	</section>
	<section class="container">
		<h2>Multiple instances of wc-beru</h2>
		<p>As we learned previously, <span>toast</span> methods accept an object as a second parameter that allows us to add more context, render a close button, and the one we will look at right now: the <span>beruId</span>. This makes it easy to choose which <span>wc-beru</span> instance we want to render our toast in. Here is an example:</p>
		<Code code={example.multipleToastsExampleOne} theme="catppuccin-latte" lang="html"></Code>
		<p>However, if we do not specify which instance we want to render our toast in, it will default to the first <span>wc-beru</span> element it finds. Assuming we want to render the toast in our element with the identifier <span>second</span>, we proceed to use our <span>beruId</span>:</p>
		<Code code={example.multipleToastsExampleTwo} theme="catppuccin-latte" lang="js"></Code>
	</section>
	<footer>
		<p>Build by <a href="https://github.com/alamguardin">Alam Guardin</a></p>
	</footer>
</Layout>

<script>
	import { toast } from "wc-beru"

	// Copy-to-clipboard
	async function copyNpmPackage(text: string) {
		try {
			await navigator.clipboard.writeText(text);
			return 'success'
		} catch (err) {
			console.log(err)
		}
	}

	const copyToClipboardButtom = document.getElementById('hero-copyToClipboard')
	const copyToClipboardText = 'pnpm add wc-beru'

	copyToClipboardButtom?.addEventListener('click', async () => {
		const wasCopyToClipboard = await copyNpmPackage(copyToClipboardText)
		wasCopyToClipboard ? toast.success('Copy to clipboard', {
			beruId: 'beru-fullcolor'
		}) : ''
	})

	// Usage section example
	const usageButton = document.getElementById('usageButton')

	usageButton?.addEventListener('click', () => {
		toast.display('👋 Hi! from wc-beru')
	})

	// Optional params secion example
	const optionalParamsButton = document.getElementById('optional-params')

	optionalParamsButton?.addEventListener('click', () => {
		toast.display('Hi Jhon', {
			description: 'This is a message from wc-beru',
			closeButton: true
		})
	})

	// Positoins section example
	const positionButtonsContainer = document.getElementById('positions')

	function renderToaster(position: string) {
		const toaster = document.createElement('wc-beru')
		toaster.setAttribute('id', 'beru-position')
		toaster.setAttribute('position', position)
		
		document.body.insertBefore(toaster, document.body.firstChild)
	}

	positionButtonsContainer?.addEventListener('click', (e) => {
		const toaster = document.getElementById('beru-position')

		if ((e.target as Element).id === 'position-top-left') {
			toaster?.remove()
			renderToaster('top-left')
			toast.display('↖️ Top left position', {
				beruId: 'beru-position'
			})
		
		}
		if ((e.target as Element).id === 'position-top-center') {
			toaster?.remove()
			renderToaster('top-center')
			toast.display('⬆️ Top center position', {
				beruId: 'beru-position'
			})
		}
		if ((e.target as Element).id === 'position-top-right') {
			toaster?.remove()
			renderToaster('top-right')
			toast.display('↗️ Top right position', {
				beruId: 'beru-position'
			})
		}

		if ((e.target as Element).id === 'position-bottom-left') {
			toaster?.remove()
			renderToaster('bottom-left')
			toast.display('↙️ Bottom left position', {
				beruId: 'beru-position'
			})
		
		}
		if ((e.target as Element).id === 'position-bottom-center') {
			toaster?.remove()
			renderToaster('bottom-center')
			toast.display('⬇️ Bottom center position', {
				beruId: 'beru-position'
			})
		
		}
		if ((e.target as Element).id === 'position-bottom-right') {
			toaster?.remove()
			renderToaster('bottom-right')
			toast.display('↘️ Bottom right position', {
				beruId: 'beru-position'
			})
		}
	})

	// Theme section example
	const switchThemeButton = document.getElementById('switch-theme')
	const themeButton = document.getElementById('theme')

	switchThemeButton?.addEventListener('click', () => {
		const toaster = document.getElementById('beru-theme')
		switchThemeButton.classList.toggle('active')

		if (toaster?.getAttribute('theme') === 'light') {
			toaster.setAttribute('theme', 'dark')
			return
		}

		if (toaster?.getAttribute('theme') === 'dark') {
			toaster.setAttribute('theme', 'light')
			return
		}

	})

	themeButton?.addEventListener('click', () => {
		toast.display('🌸 It does not matter how slowly you go as long as you do not stop', {
			description: 'Confucius',
			beruId: 'beru-theme'
		})
	})

	// Types section example
	const typeButtonsContainer = document.getElementById('types')

	typeButtonsContainer?.addEventListener('click', (e) => {
		
		if ((e.target as Element).id === 'btn-default') {
			toast.display('Application update available.')
		}

		if ((e.target as Element).id === 'btn-success') {
			toast.success('Changes saved successfully.')
		}

		if ((e.target as Element).id === 'btn-warning') {
			toast.warning('Your session is about to expire.')
		}

		if ((e.target as Element).id === 'btn-info') {
			toast.info('Low power mode activated.')
		}

		if ((e.target as Element).id === 'btn-error') {
			toast.error('Server connection failed.',)
		}
	})

	// Fullcolor section example
	const fullcolorButtonsContainer = document.getElementById('fullcolor')

	fullcolorButtonsContainer?.addEventListener('click', (e) => {
		
		if ((e.target as Element).id === 'btn-default') {
			toast.display('Application update available.', {
				beruId: 'beru-fullcolor'
			})
		}

		if ((e.target as Element).id === 'btn-success') {
			toast.success('Changes saved successfully.', {
				beruId: 'beru-fullcolor'
			})
		}

		if ((e.target as Element).id === 'btn-warning') {
			toast.warning('Your session is about to expire.', {
				beruId: 'beru-fullcolor'
			})
		}

		if ((e.target as Element).id === 'btn-info') {
			toast.info('Low power mode activated.', {
				beruId: 'beru-fullcolor'
			})
		}

		if ((e.target as Element).id === 'btn-error') {
			toast.error('Server connection failed.', {
				beruId: 'beru-fullcolor'
			})
		}
	})
</script>